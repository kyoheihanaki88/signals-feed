node_modules/

# Scout output is delivered as a CI artifact, not committed to main (Build 1 / Step D)
pipeline/candidates.json
# Local offline-test feeds only; the runner fetches live, so these stay out of the repo
pipeline/cache/

# Selection-flow daily working files (regenerated each morning, not source) — Increment 1
pipeline/review.md
pipeline/selection.yaml
pipeline/selection.json

# Writer daily working files (regenerated each morning, not source) — Writer v1
pipeline/drafts.json
pipeline/cache/articles/

# Builder draft output (never the live feed; regenerated, not source) — Builder v1
pipeline/generated/

# Python cache
__pycache__/
*.pyc
